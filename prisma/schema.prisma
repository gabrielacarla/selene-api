generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cycles    Cycle[]
}

model Cycle {
  id          Int      @id @default(autoincrement())
  startDate   DateTime
  endDate     DateTime?
  cycleLength Int?
  notes       String?

  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  symptoms    Symptom[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Symptom {
  id        Int      @id @default(autoincrement())
  name      String
  intensity Int?
  notes     String?

  cycleId   Int
  cycle     Cycle    @relation(fields: [cycleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}