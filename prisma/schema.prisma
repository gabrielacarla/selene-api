generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cycles Cycle[]
}

model Cycle {
  id          Int      @id @default(autoincrement())
  startDate   DateTime
  endDate     DateTime?
  cycleLength Int?
  notes       String?

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  symptoms Symptom[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Symptom {
  id        Int      @id @default(autoincrement())
  name      String
  intensity Int?
  notes     String?

  cycleId Int
  cycle   Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}